# ══════════════════════════════════════════════════════════════════════════════
# NeuraLife — Environment Variables
#
# Copy this file to .env and fill in the real values.
# .env is gitignored (contains secrets). NEVER commit it.
#
# Feature flags (ENABLE_*) live in .env.development / .env.production instead.
# You only need to set them here if you want to override for a one-off run.
# ══════════════════════════════════════════════════════════════════════════════

# ── SUPABASE ──────────────────────────────────────────────────────────────────
SUPABASE_URL=                       # Dashboard → Settings → API → Project URL
SUPABASE_ANON_KEY=                  # Dashboard → Settings → API → anon key
SUPABASE_SERVICE_ROLE_KEY=          # Dashboard → Settings → API → service_role key (secret)
SUPABASE_JWT_SECRET=                # Dashboard → Settings → API → JWT Settings
SUPABASE_PROJECT_REF=               # URL: app.supabase.com/project/THIS_PART

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=                    # Contents of private.pem (include newlines as \n)
JWT_PUBLIC_KEY=                     # Contents of public.pem (include newlines as \n)

# ── AWS BEDROCK (Claude) ─────────────────────────────────────────────────────
# Option A (recommended): Bedrock API Key — no IAM credentials or Marketplace needed
#   AWS Console → Bedrock → API Keys → Create API key → copy the ABSK… string
BEDROCK_API_KEY=                    # ABSK…  (takes priority over IAM creds below)

# Option B: IAM credentials (traditional — needs Bedrock model access enabled in console)
AWS_ACCESS_KEY_ID=                  # IAM user credentials CSV
AWS_SECRET_ACCESS_KEY=              # IAM user credentials CSV

AWS_REGION=us-east-1
# Model ID — find exact value in Bedrock console → Model catalog → Claude → copy "Model ID"
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ── GOOGLE GEMINI ────────────────────────────────────────────────────────────
GEMINI_API_KEY=                     # aistudio.google.com → Get API key
GEMINI_MODEL_ID=gemini-2.5-flash    # Fast structured JSON (recommended); use gemini-2.5-pro for max quality

# ── MSG91 (SMS OTP) ───────────────────────────────────────────────────────────
# Leave ENABLE_SMS_OTP=false (in .env.development) until DLT registration is complete.
MSG91_AUTH_KEY=                     # msg91.com dashboard
MSG91_SENDER_ID=NRLIFE
MSG91_OTP_TEMPLATE_ID=              # After DLT registration

# ── FIREBASE FCM ──────────────────────────────────────────────────────────────
FCM_PROJECT_ID=                     # Firebase Project Settings
FCM_CLIENT_EMAIL=                   # Service account JSON
FCM_PRIVATE_KEY=                    # Service account JSON (include \n line breaks)

# ── RESEND (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=                     # resend.com
RESEND_FROM_EMAIL=noreply@neuralife.in

# ── APP CONFIG ────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ML_INTERNAL_API_KEY=                # Shared secret between api and ml service

# ── FEATURE FLAGS (override only; normally set in .env.development/.env.production)
# ENABLE_SMS_OTP=false              # true = real MSG91 SMS; false = OTP in API response
# ENABLE_RATE_LIMIT=false           # true = HTTP + OTP rate limits; false = unlimited (dev)
# ENABLE_EMAIL=false                # true = real Resend emails; false = log to console
# ENABLE_FCM_PUSH=false             # true = real FCM push; false = skip
