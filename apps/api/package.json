    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.0.0",
    "@google/generative-ai": "^0.24.1",
    "@neuralife/shared": "workspace:^",
    "@supabase/supabase-js": "^2.46.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.0.0",
